<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500" prefWidth="680" stylesheets="@table.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.osproject.ComparisonController">

    <children>

        <Button layoutX="300.0" layoutY="185.0" mnemonicParsing="false" onAction="#result" text="Compare" />
        <Button fx:id="bac" layoutX="42.0" layoutY="161.0" mnemonicParsing="false" onAction="#goToInput" text="Input" />
        <Button fx:id="rb" layoutX="42.0" layoutY="35.0" mnemonicParsing="false" onAction="#goToRR" prefHeight="28.0" prefWidth="59.0" text="RR" />
        <Button fx:id="sb" layoutX="42.0" layoutY="100.0" mnemonicParsing="false" onAction="#goToSJF" prefHeight="28.0" prefWidth="59.0" text="SJF" />

        <TableView fx:id="table" layoutX="160.0" layoutY="24.0" prefHeight="151.0" prefWidth="360">

            <columns>
                <TableColumn fx:id="met" prefWidth="120" text="Metric" />
                <TableColumn fx:id="rr" prefWidth="120" text="RR" />
                <TableColumn fx:id="sjf" prefWidth="120" text="SRTF" />
            </columns>

        </TableView>
        <HBox fx:id="rq" alignment="CENTER" layoutX="160.0" layoutY="301.0" prefHeight="60" prefWidth="360" spacing="5" style="-fx-border-color: #5ad9bb; -fx-padding: 5;">
        </HBox>
        <Label fx:id="ti" alignment="CENTER" contentDisplay="CENTER" layoutX="213.0" layoutY="257.0" prefHeight="18.0" prefWidth="277.0" text="Round Robin Ready Queue" textAlignment="CENTER" textFill="#efdede">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Label>
        <HBox layoutX="190.0" layoutY="368.0" prefHeight="34.0" prefWidth="297.0">
            <children>
                <Button fx:id="pr" mnemonicParsing="false" onAction="#prev" text="◀ Prev" />
                <Label fx:id="time" alignment="CENTER" prefHeight="34.0" prefWidth="130.0" style="-fx-background-color: white;" text="T=0" />
                <Button fx:id="ne" mnemonicParsing="false" onAction="#next" prefHeight="34.0" prefWidth="79.0" text="Next ▶" />
            </children>
        </HBox>


        <StackPane fx:id="overlay"
                   alignment="CENTER"
                   prefHeight="500"
                   prefWidth="680"
                   style="-fx-background-color: rgba(0,0,0,0.35);"
                   visible="false">

            <children>

                <VBox alignment="CENTER"
                      prefHeight="160"
                      prefWidth="220"
                      spacing="10"
                      style="-fx-background-color: #0d47a1;
                     -fx-padding: 12;
                     -fx-background-radius: 12;
                     -fx-border-radius: 12;
                     -fx-border-color: #90caf9;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0.3, 0, 3);">

                    <Label text="Comparison Result"
                           style="-fx-text-fill: #e3f2fd;
                          -fx-font-size: 13px;
                          -fx-font-weight: bold;" />

                    <Label fx:id="resultt"
                           alignment="CENTER"
                           maxWidth="200"
                           wrapText="true"
                           textAlignment="CENTER"
                           style="-fx-text-fill: #bbdefb;
                          -fx-font-size: 12px;" />

                    <Button text="Close"
                            onAction="#closeOverlay"
                            style="-fx-background-color: #2196f3;
                           -fx-text-fill: white;" />

                </VBox>

            </children>

        </StackPane>





    </children>

</AnchorPane>