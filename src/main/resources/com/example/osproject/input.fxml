<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.osproject.InputController">
   <left>
      <VBox styleClass="left-pane" alignment="CENTER" prefHeight="476.0" prefWidth="200.0" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <TextField fx:id="processid" promptText="process id" />
            <TextField fx:id="arrival" promptText="arrival time" />
            <Label fx:id="L2">
               <VBox.margin>
                  <Insets bottom="-20.0" left="-40.0" top="-20.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="burst" promptText="burst time" />
            <Label fx:id="L3">
               <VBox.margin>
                  <Insets bottom="-20.0" left="-40.0" top="-20.0" />
               </VBox.margin>
            </Label>
            <Label fx:id="L4">
               <VBox.margin>
                  <Insets bottom="-10.0" left="-40.0" top="-15.0" />
               </VBox.margin>
            </Label>
            <HBox prefHeight="28.0" prefWidth="170.0" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" fx:id="addBtn" onAction="#addProcess" text="add">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin></Button>
                  <Button mnemonicParsing="false" fx:id="clearBtn" onAction="#clear" text="clear" />
               </children>
               <VBox.margin>
                  <Insets top="-5.0" />
               </VBox.margin>
            </HBox>
            <VBox prefHeight="95.0" prefWidth="170.0" spacing="10.0">
               <children>
                  <Button lineSpacing="5.0" styleClass="run-btn" mnemonicParsing="false" onAction="#goToRR" text="Run RR" />
                  <Button mnemonicParsing="false" styleClass="run-btn" onAction="#goToSJF" text="Run SJF" />
                  <Button mnemonicParsing="false" styleClass="run-btn" onAction="#goToComparison" text="Run CT,RQ" />
               </children>
            </VBox>
         </children>
         <padding>
            <Insets left="10.0" right="20.0" />
         </padding>
      </VBox>
   </left>
   <right>
      <VBox spacing="15.0" styleClass="right-pane">
      <TableView fx:id="table" prefHeight="221.0" prefWidth="250.0" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="PID" prefWidth="63.20001220703125" text="PID" />
            <TableColumn fx:id="AT" minWidth="0.0" prefWidth="91.79998779296875" text="Arrival time" />
            <TableColumn fx:id="BT" prefWidth="93.0" text="Brust time" />
         </columns>
         <BorderPane.margin>
            <Insets bottom="170.0" left="100.0" right="50.0" top="90.0" />
         </BorderPane.margin>
            <VBox.margin>
               <Insets right="25.0" top="100.0" />
            </VBox.margin>
      </TableView>
         <TextField fx:id="quantum" prefHeight="12.0" prefWidth="126.0" promptText="quantum">
            <VBox.margin>
               <Insets right="100.0" />
            </VBox.margin></TextField>
         <Label fx:id="L" lineSpacing="5.0" />
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
      </VBox>
   </right>
   <top>
      <Label fx:id="welcomeLabel" text="Welcome in Round Robin vs SJF Comparison Project" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets top="10.0" />
         </BorderPane.margin>
      </Label>
   </top>
</BorderPane>
